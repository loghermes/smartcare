<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.smartcare.smartcaredesktop.controller.DoctorManagementController"
            prefWidth="1300" prefHeight="700">

    <!-- ================= FORM ================= -->
    <top>
        <VBox spacing="15" style="-fx-padding:20;">
            <Label text="Doctor Management"
                   style="-fx-font-size:22px; -fx-font-weight:bold;"/>

            <GridPane hgap="10" vgap="10">

                <!-- Row 0 -->
                <Label text="First Name:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="firstNameField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Last Name:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                <TextField fx:id="lastNameField" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                <!-- Row 1 -->
                <Label text="Slug:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="slugField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Gender:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                <ComboBox fx:id="genderComboBox" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                <!-- Row 2 -->
                <Label text="Profile Photo:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <TextField fx:id="profilePhotoField" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <Button text="Browse"
                        onAction="#handleBrowsePhoto"
                        GridPane.rowIndex="2"
                        GridPane.columnIndex="2"/>

                <!-- Row 3 -->
                <Label text="Specialization:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <TextField fx:id="specializationField" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                <Label text="License:" GridPane.rowIndex="3" GridPane.columnIndex="2"/>
                <TextField fx:id="licenseField" GridPane.rowIndex="3" GridPane.columnIndex="3"/>

                <!-- Row 4 -->
                <Label text="Phone:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                <TextField fx:id="phoneField" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                <Label text="Experience:" GridPane.rowIndex="4" GridPane.columnIndex="2"/>
                <TextField fx:id="experienceField" GridPane.rowIndex="4" GridPane.columnIndex="3"/>

                <!-- Row 5 -->
                <Label text="Bio:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                <TextArea fx:id="bioField"
                          prefRowCount="2"
                          GridPane.rowIndex="5"
                          GridPane.columnIndex="1"
                          GridPane.columnSpan="3"/>

                <!-- Row 6 -->
                <Label text="Available:" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                <CheckBox fx:id="availableCheckBox"
                          GridPane.rowIndex="6"
                          GridPane.columnIndex="1"/>

                <!-- Row 7 -->
                <Label text="Email:" GridPane.rowIndex="7" GridPane.columnIndex="0"/>
                <TextField fx:id="emailField" GridPane.rowIndex="7" GridPane.columnIndex="1"/>

                <Label text="Username:" GridPane.rowIndex="7" GridPane.columnIndex="2"/>
                <TextField fx:id="usernameField" GridPane.rowIndex="7" GridPane.columnIndex="3"/>

                <!-- Row 8 -->
                <Label text="Password:" GridPane.rowIndex="8" GridPane.columnIndex="0"/>
                <PasswordField fx:id="passwordField"
                               GridPane.rowIndex="8"
                               GridPane.columnIndex="1"/>

                <Button text="Add Doctor"
                        GridPane.rowIndex="8"
                        GridPane.columnIndex="3"
                        onAction="#handleAddDoctor"/>

            </GridPane>
        </VBox>
    </top>

    <!-- ================= TABLE ================= -->
    <center>
        <TableView fx:id="doctorTable" VBox.vgrow="ALWAYS">

            <columns>
                <TableColumn fx:id="firstNameColumn" text="First Name" prefWidth="100"/>
                <TableColumn fx:id="lastNameColumn" text="Last Name" prefWidth="100"/>
                <TableColumn fx:id="slugColumn" text="Slug" prefWidth="100"/>
                <TableColumn fx:id="genderColumn" text="Gender" prefWidth="80"/>
                <TableColumn fx:id="profilePhotoColumn" text="Photo" prefWidth="120"/>
                <TableColumn fx:id="specializationColumn" text="Specialization" prefWidth="140"/>
                <TableColumn fx:id="licenseColumn" text="License" prefWidth="100"/>
                <TableColumn fx:id="phoneColumn" text="Phone" prefWidth="100"/>
                <TableColumn fx:id="experienceColumn" text="Experience" prefWidth="90"/>
                <TableColumn fx:id="bioColumn" text="Bio" prefWidth="150"/>
                <TableColumn fx:id="availableColumn" text="Available" prefWidth="80"/>
                <TableColumn fx:id="createdAtColumn" text="Created At" prefWidth="140"/>
                <TableColumn fx:id="updatedAtColumn" text="Updated At" prefWidth="140"/>
            </columns>

        </TableView>
    </center>

</BorderPane>