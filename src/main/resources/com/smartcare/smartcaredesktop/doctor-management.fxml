<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.smartcare.smartcaredesktop.controller.DoctorManagementController"
            prefWidth="1300" prefHeight="700">

    <!-- ================= FORM ================= -->
    <top>
        <VBox spacing="15" style="-fx-padding:20;">
            <Label text="Doctor Management"
                   style="-fx-font-size:22px; -fx-font-weight:bold;"/>

            <GridPane hgap="10" vgap="10">

                <Label text="First Name:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="firstNameField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Last Name:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                <TextField fx:id="lastNameField" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                <Label text="Slug:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="slugField"
                           editable="false"
                           GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Gender:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                <ComboBox fx:id="genderComboBox" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                <Label text="Profile Photo:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <HBox spacing="10" GridPane.rowIndex="2" GridPane.columnIndex="1">
                    <Button text="Choose File" onAction="#handleBrowsePhoto"/>
                    <Label fx:id="photoNameLabel" text="No file selected"/>
                </HBox>

                <Label text="Specialization:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <TextField fx:id="specializationField" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                <Label text="License:" GridPane.rowIndex="3" GridPane.columnIndex="2"/>
                <TextField fx:id="licenseField" GridPane.rowIndex="3" GridPane.columnIndex="3"/>

                <Label text="Phone:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                <TextField fx:id="phoneField" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                <Label text="Experience:" GridPane.rowIndex="4" GridPane.columnIndex="2"/>
                <TextField fx:id="experienceField" GridPane.rowIndex="4" GridPane.columnIndex="3"/>

                <Label text="Bio:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                <TextArea fx:id="bioField"
                          prefRowCount="2"
                          GridPane.rowIndex="5"
                          GridPane.columnIndex="1"
                          GridPane.columnSpan="3"/>

                <Label text="Email:" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                <TextField fx:id="emailField" GridPane.rowIndex="6" GridPane.columnIndex="1"/>

                <Label text="Username:" GridPane.rowIndex="6" GridPane.columnIndex="2"/>
                <TextField fx:id="usernameField" GridPane.rowIndex="6" GridPane.columnIndex="3"/>

                <HBox spacing="10" GridPane.rowIndex="7" GridPane.columnIndex="3">
                    <Button text="Add" onAction="#handleAddDoctor"/>
                    <Button text="Update" onAction="#handleUpdateDoctor"/>
                    <Button text="Delete" onAction="#handleDeleteDoctor"/>
                </HBox>

            </GridPane>
        </VBox>
    </top>

    <!-- ================= TABLE ================= -->
    <center>
        <TableView fx:id="doctorTable">

            <columns>
                <TableColumn fx:id="firstNameColumn" text="First Name"/>
                <TableColumn fx:id="lastNameColumn" text="Last Name"/>
                <TableColumn fx:id="slugColumn" text="Slug"/>
                <TableColumn fx:id="specializationColumn" text="Specialization"/>
                <TableColumn fx:id="phoneColumn" text="Phone"/>
            </columns>

        </TableView>
    </center>

</BorderPane>